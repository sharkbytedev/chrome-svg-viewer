{
  "manifest_version": 3,
  "name": "SVG Viewer+",
  "version": "1.0.0",
  "description": "Change the background color when viewing SVG files in the browser.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "web_accessible_resources": [{
    "resources": ["sharkbyte-logo.svg"],
    "matches": ["<all_urls>"]
  }]
}
